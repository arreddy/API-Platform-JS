# API Management Platform - Environment Configuration

# ============================================
# Node Environment
# ============================================
NODE_ENV=development
PORT=3000
LOG_LEVEL=info

# ============================================
# Database Configuration (PostgreSQL)
# ============================================
DB_USER=postgres
DB_PASSWORD=postgres
DB_HOST=postgres
DB_PORT=5432
DB_NAME=api_management
DB_POOL_MIN=5
DB_POOL_MAX=50

# ============================================
# Redis Configuration (Caching & Sessions)
# ============================================
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_TTL=3600

# ============================================
# Authentication & JWT
# ============================================
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production-minimum-32-chars
JWT_EXPIRY=3600
JWT_REFRESH_EXPIRY=2592000

# ============================================
# API Configuration
# ============================================
API_VERSION=v1
API_BASE_PATH=/api/v1
MAX_REQUEST_SIZE=50mb
REQUEST_TIMEOUT=30000

# ============================================
# CORS Configuration
# ============================================
CORS_ORIGIN=http://localhost:3000,http://localhost:3001,http://localhost:5173
CORS_CREDENTIALS=true

# ============================================
# Storage Configuration (for OAS files)
# ============================================
STORAGE_TYPE=local
# STORAGE_TYPE=s3 (uncomment for S3)
# S3_BUCKET=api-management-specs
# S3_REGION=us-east-1
# S3_ACCESS_KEY_ID=your-access-key
# S3_SECRET_ACCESS_KEY=your-secret-key

# ============================================
# Elasticsearch Configuration (Analytics)
# ============================================
ELASTICSEARCH_HOST=elasticsearch:9200
ELASTICSEARCH_USERNAME=
ELASTICSEARCH_PASSWORD=
ELASTICSEARCH_INDEX_PREFIX=api-platform
ELASTICSEARCH_LOG_RETENTION_DAYS=30

# ============================================
# Email Configuration (SMTP)
# ============================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=true
SMTP_USER=noreply@example.com
SMTP_PASSWORD=your-app-password
SMTP_FROM_EMAIL=noreply@api-platform.example.com
SMTP_FROM_NAME=API Management Platform

# ============================================
# OAuth2 Configuration (Optional)
# ============================================
OAUTH2_ENABLED=false
OAUTH2_GOOGLE_CLIENT_ID=
OAUTH2_GOOGLE_CLIENT_SECRET=
OAUTH2_GITHUB_CLIENT_ID=
OAUTH2_GITHUB_CLIENT_SECRET=
OAUTH2_GITHUB_REDIRECT_URI=http://localhost:3000/api/v1/auth/github/callback

# ============================================
# Rate Limiting
# ============================================
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=1000
RATE_LIMIT_SKIP_SUCCESSFUL_REQUESTS=false

# ============================================
# API Key Configuration
# ============================================
API_KEY_PREFIX=sk_live_
API_KEY_LENGTH=32
API_KEY_EXPIRY_DAYS=365

# ============================================
# Data Plane Gateway Configuration
# ============================================
DATA_PLANE_PORT=3001
DATA_PLANE_HOST=0.0.0.0
GATEWAY_TIMEOUT_MS=30000
GATEWAY_ENABLE_COMPRESSION=true
GATEWAY_ENABLE_CACHING=true
GATEWAY_CACHE_TTL_SECONDS=300

# ============================================
# Security
# ============================================
ENABLE_HTTPS=false
SSL_CERT_PATH=/etc/ssl/certs/tls.crt
SSL_KEY_PATH=/etc/ssl/private/tls.key
ENABLE_HELMET=true
ENABLE_HPP=true

# ============================================
# Logging & Monitoring
# ============================================
LOG_FORMAT=json
LOG_TO_FILE=true
LOG_FILE_PATH=./logs/app.log
LOG_FILE_MAX_SIZE=10m
LOG_FILE_MAX_FILES=10

# ============================================
# Sentry Error Tracking (Optional)
# ============================================
SENTRY_ENABLED=false
SENTRY_DSN=
SENTRY_ENVIRONMENT=development
SENTRY_TRACES_SAMPLE_RATE=0.1

# ============================================
# Analytics Event Tracking (Optional)
# ============================================
ANALYTICS_ENABLED=true
ANALYTICS_BATCH_SIZE=100
ANALYTICS_FLUSH_INTERVAL_MS=5000

# ============================================
# Feature Flags
# ============================================
FEATURE_MOCK_SERVER_ENABLED=true
FEATURE_ANALYTICS_ENABLED=true
FEATURE_AUDIT_LOGGING_ENABLED=true
FEATURE_WEBHOOKS_ENABLED=false
FEATURE_AI_SUGGESTIONS_ENABLED=false

# ============================================
# Developer Portal Configuration
# ============================================
PORTAL_URL=http://localhost:5173
PORTAL_ENABLE_SWAGGER_UI=true
PORTAL_ENABLE_REDOC=true
PORTAL_ENABLE_API_TESTING=true

# ============================================
# Deployment Configuration
# ============================================
ENVIRONMENT=development
DEPLOYMENT_TYPE=docker-compose
# DEPLOYMENT_TYPE=kubernetes (for K8s)
DEPLOYMENT_NAMESPACE=api-management

# ============================================
# External Service Integration
# ============================================
# GitHub Integration
GITHUB_INTEGRATION_ENABLED=false
GITHUB_ORG=
GITHUB_WEBHOOK_SECRET=

# GitLab Integration
GITLAB_INTEGRATION_ENABLED=false
GITLAB_WEBHOOK_SECRET=

# ============================================
# Backup & Disaster Recovery
# ============================================
BACKUP_ENABLED=true
BACKUP_SCHEDULE=0 2 * * *
BACKUP_RETENTION_DAYS=30

# ============================================
# Advanced Configuration
# ============================================
# Multi-tenancy
ENABLE_MULTI_TENANCY=true
TENANT_ISOLATION_LEVEL=strict

# Request/Response Transformation
MAX_TRANSFORMATION_SIZE=1024000

# OAS Validation
OAS_STRICT_VALIDATION=true
OAS_ALLOW_EXTENSIONS=true

# ============================================
# Development Only
# ============================================
DEBUG=api-platform:*
MOCK_EXTERNAL_SERVICES=false
SEED_DATABASE=true
